<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles/main.css">
  <title>Book Tracker</title>
</head>
<body>

  <header>
    <div class="hero">
      <h1>My Book Tracker</h1>
      <a href="/"><p>Home</p></a>
    </div>
  </header>

  <div class="books">

    <%# novalidate removes the browser "Please fill out this field" tooltip %>
    <form class="book-search" id="searchForm" action="/search" method="get" novalidate>
      <input type="text" id="searchInput" name="q" placeholder="Search your library…">
      <button type="submit">Search</button>
    </form>

    <a class="add-book" href="/add">+ Add New Book</a>

    <% if (typeof message !== 'undefined' && message) { %>
      <p class="status-msg"><%= message %></p>
    <% } else if (books && books.length > 0) { %>

      <% books.forEach(book => { %>
        <div class="book">
          <div class="book-details">
            <img src="<%= book.cover_url %>" alt="Cover of <%= book.title %>">
            <div class="book-info">
              <h3><strong><%= book.title %></strong></h3>
              <h4>by <%= book.author %></h4>
              <h4>Review:</h4>
              <p><%= book.review || 'No review yet.' %></p>
              <div class="button edit">
                <a href="/edit/<%= book.id %>"><button type="button">Edit</button></a>
                <form action="/delete/<%= book.id %>" method="post" style="display:inline;">
                  <button type="submit">Delete</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }); %>

    <% } else { %>
      <p class="status-msg">Your library is empty. <a href="/add">Add your first book!</a></p>
    <% } %>

  </div>

  <footer>Copyright &copy; chimax: <%= new Date().getFullYear() %></footer>

  <script>
    // Prevent empty search without triggering browser's built-in validation tooltip
    document.getElementById('searchForm').addEventListener('submit', function (e) {
      const val = document.getElementById('searchInput').value.trim();
      if (!val) {
        e.preventDefault();
        const input = document.getElementById('searchInput');
        input.placeholder = 'Type something to search your library…';
        input.classList.add('input-shake');
        setTimeout(() => input.classList.remove('input-shake'), 500);
      }
    });
  </script>

</body>
</html>
